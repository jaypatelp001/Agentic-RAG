# ── LexRAG Environment Variables ──────────────────────────────────────────────
# Copy this to .env and fill in your values. Never commit .env to git.

# Gemini
GEMINI_API_KEY=your_gemini_api_key_here

# Qdrant (local Docker — no key needed for local)
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=lexrag_legal_docs

# Tavily (web search fallback for CRAG)
TAVILY_API_KEY=your_tavily_api_key_here

# Redis (query cache)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_TTL_SECONDS=3600

# LangFuse (observability — get keys from cloud.langfuse.com)
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key
LANGFUSE_SECRET_KEY=your_langfuse_secret_key
LANGFUSE_HOST=https://cloud.langfuse.com

# SQLite path (Adaptive RAG metadata DB)
SQLITE_DB_PATH=./data/lexrag_metadata.db

# Chunking config
CHUNK_SIZE=800
CHUNK_OVERLAP=150

# Retrieval config
TOP_K_RESULTS=5
RELEVANCE_THRESHOLD=0.75
